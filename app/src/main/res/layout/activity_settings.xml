<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_surface"
        app:titleTextColor="@color/text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ① সেভ করা Playlist লিঙ্ক -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 সেভ করা Playlist লিঙ্কগুলো"
                android:textColor="@color/accent_green"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="এখানে আপনার যোগ করা সব M3U লিঙ্ক দেখতে, কপি করতে বা Edit করতে পারবেন।"
                android:textColor="#88FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <!-- Dynamic list — Java থেকে populate হবে -->
            <LinearLayout
                android:id="@+id/llSavedPlaylists"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#22FFFFFF" android:layout_marginVertical="20dp" />

            <!-- ② Quick URL যোগ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔗 Quick URL যোগ করুন"
                android:textColor="@color/accent_green"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="এই URL টি সরাসরি Bangladesh ক্যাটাগরিতে যোগ হবে (Playlist ছাড়া)।"
                android:textColor="#88FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etCustomUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="https://example.com/playlist.m3u8"
                android:textColorHint="#55FFFFFF"
                android:textColor="@color/text_primary"
                android:background="@drawable/search_bg"
                android:padding="14dp"
                android:inputType="textUri"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button android:id="@+id/btnPasteUrl"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:text="📋 পেস্ট" android:textColor="@color/text_primary"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button android:id="@+id/btnClearUrl"
                    android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                    android:text="🗑️ মুছুন" android:textColor="@color/accent_red"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <Button android:id="@+id/btnSaveUrl"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="✅ সেভ করুন"
                android:backgroundTint="@color/accent_green"
                android:textColor="#000000" android:textStyle="bold" android:textSize="16sp"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.Button" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#22FFFFFF" android:layout_marginBottom="20dp" />

            <!-- ③ Parental Control -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒 Parental Control"
                android:textColor="@color/accent_green"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="চ্যানেল লক করতে PIN ব্যবহার হয়। Default PIN: 1234"
                android:textColor="#88FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <Button android:id="@+id/btnChangePin"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="🔑 PIN পরিবর্তন করুন"
                android:backgroundTint="#221A1A2E"
                android:textColor="@color/accent_green"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#22FFFFFF" android:layout_marginBottom="20dp" />

            <!-- ④ অ্যাপ তথ্য -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ℹ️ অ্যাপ তথ্য"
                android:textColor="@color/accent_green"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="অ্যাপের নাম: Zayaan TV\nভার্সন: 1.0\nচ্যানেল সোর্স: GitHub iptv-org + আকাশ DTH\nবিশ্বকাপ সম্প্রচার: BTV, T Sports, Somoy TV"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5"
                android:background="@drawable/card_bg"
                android:padding="14dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>