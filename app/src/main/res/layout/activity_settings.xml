<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/bg_surface"
        app:titleTextColor="@color/text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- World Cup সেকশন -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚽ ফুটবল বিশ্বকাপ ২০২৬"
                android:textColor="@color/accent_green"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:background="@drawable/card_bg"
                android:padding="14dp"
                android:layout_marginBottom="24dp" />

            <!-- Custom M3U URL সেকশন -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔗 কাস্টম M3U URL যোগ করুন"
                android:textColor="@color/accent_green"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="নিজের M3U/M3U8 লিংক যোগ করলে সেটি Bangladesh ক্যাটাগরিতে যোগ হবে।"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <!-- URL Input -->
            <EditText
                android:id="@+id/etCustomUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="https://example.com/playlist.m3u8"
                android:textColorHint="#55FFFFFF"
                android:textColor="@color/text_primary"
                android:background="@drawable/search_bg"
                android:padding="14dp"
                android:inputType="textUri"
                android:textSize="13sp"
                android:layout_marginBottom="10dp" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnPasteUrl"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📋 পেস্ট"
                    android:backgroundTint="#222A3A5C"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <Button
                    android:id="@+id/btnClearUrl"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🗑️ মুছুন"
                    android:backgroundTint="#22FF4757"
                    android:textColor="@color/accent_red"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            </LinearLayout>

            <Button
                android:id="@+id/btnSaveUrl"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✅ সেভ করুন"
                android:backgroundTint="@color/accent_green"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="16sp"
                style="@style/Widget.MaterialComponents.Button" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#22FFFFFF"
                android:layout_marginVertical="24dp" />

            <!-- অ্যাপ তথ্য -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ℹ️ অ্যাপ তথ্য"
                android:textColor="@color/accent_green"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="অ্যাপের নাম: Zayaan TV\nভার্সন: 1.0\nচ্যানেল সোর্স: GitHub iptv-org + আকাশ DTH\nবিশ্বকাপ সম্প্রচার: BTV, T Sports, Somoy TV"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5"
                android:background="@drawable/card_bg"
                android:padding="14dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>