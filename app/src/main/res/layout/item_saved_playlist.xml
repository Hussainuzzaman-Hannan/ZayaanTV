<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_bg"
    android:layout_marginBottom="10dp"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvSavedName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnTestPlaylist"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:text="🔍"
            android:textSize="16sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <ImageButton
            android:id="@+id/btnCopyUrl"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_copy"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/accent_green" />

        <ImageButton
            android:id="@+id/btnEditUrl"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/accent_gold" />

        <ImageButton
            android:id="@+id/btnDeleteSaved"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/accent_red" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvSavedUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="middle"
        android:layout_marginTop="4dp"
        android:fontFamily="monospace" />

</LinearLayout>